# Copy this file to .env and fill in real values for local development.
# Local Postgres (pgvector) connection string. Must match docker-compose.yml credentials.
DATABASE_URL="postgresql://kyron:kyron_dev_password@localhost:5433/kyron_scribe?schema=public"

# Node environment: development | test | production
NODE_ENV="development"

# Auth
# Name of the HTTP-only session cookie.
SESSION_COOKIE_NAME="session_token"
# Session lifetime in hours.
SESSION_TTL_HOURS="24"

# OpenAI
# Server-side API key used for embeddings and (later) generation.
OPENAI_API_KEY=""
# Embedding model. vector(1536) column is tied to text-embedding-3-small.
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
# SOAP generation model used by the streaming endpoint.
OPENAI_SOAP_GENERATION_MODEL="gpt-4o-mini"
# Structured-output model used to extract clinical problems before ICD-10 retrieval.
OPENAI_PROBLEM_EXTRACT_MODEL="gpt-4o-mini"
# Realtime (WebRTC) live dictation transcription model.
OPENAI_REALTIME_TRANSCRIBE_MODEL="gpt-4o-transcribe"
# Recorded-audio fallback transcription model (file upload).
OPENAI_FILE_TRANSCRIBE_MODEL="gpt-4o-mini-transcribe"
