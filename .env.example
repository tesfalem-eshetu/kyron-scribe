# Copy this file to .env and fill in real values for local development.
# Local Postgres (pgvector) connection string. Must match docker-compose.yml credentials.
DATABASE_URL="postgresql://kyron:kyron_dev_password@localhost:5433/kyron_scribe?schema=public"

# Node environment: development | test | production
NODE_ENV="development"

# Auth
# Name of the HTTP-only session cookie.
SESSION_COOKIE_NAME="session_token"
# Session lifetime in hours.
SESSION_TTL_HOURS="24"
