# Copy to terraform.tfvars and edit. terraform.tfvars is git-ignored.

region       = "us-east-1"
project_name = "kyron-scribe"

# REQUIRED: the domain/subdomain you will point at the server for HTTPS.
domain_name = "scribe.example.com"

# Sizing (defaults are small/cheap).
instance_type     = "t3.small"
db_instance_class = "db.t4g.micro"

# Optional SSH access. Leave admin_cidr empty to use SSM Session Manager only.
# admin_cidr   = "203.0.113.4/32"
# ssh_key_name = "my-ec2-keypair"
